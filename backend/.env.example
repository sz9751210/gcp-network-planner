# Database
DATABASE_URL="postgresql://user:password@localhost:5432/gcp_network_planner?schema=public"
# For SQLite (development):
# DATABASE_URL="file:./dev.db"

# Encryption key for storing service account credentials
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-32-byte-hex-encryption-key-here-change-in-production"

# Server configuration
PORT=3001
NODE_ENV=development

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS="http://localhost:3000"
