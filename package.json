{
  "name": "gcp-network-planner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "cd go-backend && GOCACHE=/tmp/go-build make run",
    "legacy:backend:node": "npm --prefix backend run dev",
    "build": "npm run build --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "cd go-backend && GOCACHE=/tmp/go-build go build -o bin/server ./cmd/main.go",
    "typecheck": "npm run typecheck --workspace=frontend",
    "test:backend": "cd go-backend && GOCACHE=/tmp/go-build go test ./...",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "workspaces": ["frontend", "backend"],
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
